GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
OLLAMA_BASE_URL=http://ollama:11434
# Fallback model when the request doesn't specify one (qwen2.5 | llama3.1 | qwen3:14b)
OLLAMA_MODEL=qwen2.5
# How long Ollama keeps a model in VRAM after a request (e.g. 5m, 30s, 0 to unload immediately)
OLLAMA_KEEP_ALIVE=5m
