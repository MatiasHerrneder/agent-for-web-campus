{
  "manifest_version": 3,
  "name": "Aula Virtual Assistant - UNLu",
  "version": "1.0.0",
  "description": "Asistente de IA para el Aula Virtual de la Universidad Nacional de Luján",
  "permissions": [
    "cookies",
    "activeTab",
    "storage",
    "sidePanel"
  ],
  "host_permissions": [
    "https://platdig.unlu.edu.ar/*",
    "http://localhost:8000/*"
  ],
  "action": {
    "default_title": "Aula Virtual Assistant"
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
